{
  "name": "bun-gas",
  "version": "0.0.1",
  "description": "Bun template for Google Apps Script",
  "author": "ncukondo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ncukondo/bun-gas.git"
  },
  "homepage": "https://github.com/ncukondo/bun-gas",
  "type": "module",
  "module": "index.ts",
  "devDependencies": {
    "@google/clasp": "^3.3.0",
    "@topcli/prompts": "^3.1.0",
    "@types/bun": "^1.3.12",
    "@types/fs-extra": "^11.0.4",
    "@types/google-apps-script": "^2.0.8",
    "bun-types": "^1.3.12",
    "fs-extra": "^11.3.4",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "vite": "^8.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "bun-create": {
    "postinstall": "bun run ./bin/init/index.ts"
  },
  "scripts": {
    "build": "bun run ./bin/build.ts src/index.ts dist/index.js",
    "init": "bun run ./bin/init/index.ts",
    "deploy": "bun run ./bin/deploy.ts",
    "deploy:prod": "bun run ./bin/deploy.ts --prod",
    "push": "bun run ./bin/push.ts",
    "push:prod": "bun run ./bin/push.ts --prod",
    "open": "bun run ./bin/open.ts",
    "open:prod": "bun run ./bin/open.ts --prod",
    "lint": "bunx oxlint",
    "format": "bunx oxfmt",
    "format:check": "bunx oxfmt --check"
  }
}